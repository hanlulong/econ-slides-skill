% econ-slides-house.sty — default theme of the econ-slides skill
%
% The "house" look: no chrome, 16:9, Palatino, Okabe-Ito semantic palette,
% gray current/total footer with the appendix excluded and renumbered A1, A2, ...
%
% Usage:
%   \documentclass[11pt, aspectratio=169]{beamer}
%   \usepackage{econ-slides-house}
%
% Every econ-slides theme implements the same semantic interface, so decks
% switch themes by swapping this one \usepackage line:
%   colors   cAccentA cAccentB cAccentC cAccentD cHighlight cGood cBad
%   macros   \KeyIdea{...} \Takeaway{...} \graycite{...} \Et
%   nav      \PlaceNav{...} \PlaceNavShift{<xshift>}{...} \BackButton{<label>}
%   frames   \begin{ResultBox}[title] ... \end{ResultBox} and \AppendixStart
%
% Part of econ-slides (https://github.com/hanlulong/econ-slides-skill). MIT.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{econ-slides-house}[2026/07/15 econ-slides house theme]

% ---- Core packages ----
\RequirePackage{amsmath,amssymb,bm}
\RequirePackage{booktabs,array,multirow,multicol}
\RequirePackage{threeparttable}
\RequirePackage{graphicx}
\RequirePackage{tcolorbox}
\RequirePackage{mathpazo}                 % Palatino text + math: the signature font
\RequirePackage{tikz}
\usetikzlibrary{arrows.meta,positioning,calc}
\RequirePackage{xcolor}
\RequirePackage{appendixnumberbeamer}     % exclude appendix from total, restart numbering

% ---- Theme: strip all chrome ----
\usetheme{default}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{frametitle}[default][center]
\setbeamersize{text margin left=2em, text margin right=2em}
% Math-mode bullet, NOT \textbullet: mathpazo has no \textbullet glyph under
% xelatex/lualatex, so \textbullet silently renders as a tofu square there.
\setbeamertemplate{itemize item}{\raise0.9pt\hbox{\small$\bullet$}}
\setbeamertemplate{itemize subitem}{\tiny$\blacksquare$}
\setbeamertemplate{itemize subsubitem}{$\star$}
\setbeamerfont{button}{size=\scriptsize}
% Frame titles and the title page keep beamer's defaults on purpose:
% \Large, structure color (the classic dark blue), medium weight — the
% original house look. Pin the blue so a beamer default change can't move it.
\definecolor{esStructure}{rgb}{0.2,0.2,0.7}
\setbeamercolor{structure}{fg=esStructure}
\setbeamerfont{framesubtitle}{size=\small, shape=\itshape}
\setbeamercolor{framesubtitle}{fg=black!70}
% Breathing room between top-level bullets (nested lists stay tight)
\setbeamertemplate{itemize/enumerate body begin}{\setlength{\itemsep}{0.45em}}

% ---- Okabe-Ito colorblind-safe palette (assign ONE color per recurring concept) ----
\definecolor{cAccentA}{HTML}{0072B2}   % blue
\definecolor{cAccentB}{HTML}{D55E00}   % vermillion
\definecolor{cAccentC}{HTML}{009E73}   % teal/green
\definecolor{cAccentD}{HTML}{E69F00}   % amber
\definecolor{cHighlight}{rgb}{0.78,0.08,0.52}  % magenta spotlight
\colorlet{cGood}{cAccentC}
\colorlet{cBad}{cAccentB}

% ---- Footer: gray "current / total", appendix excluded then renumbered A# ----
% appendixnumberbeamer makes \inserttotalframenumber the last main-part frame
% and restarts \insertframenumber inside the appendix.
\newif\ifecoslides@appendix
\ecoslides@appendixfalse
\let\ecoslides@origappendix\appendix
\renewcommand{\appendix}{\ecoslides@origappendix\ecoslides@appendixtrue}
\setbeamertemplate{footline}{%
  \hfill{\color{gray}\scriptsize
    \ifecoslides@appendix A\insertframenumber
    \else\insertframenumber\,/\,\inserttotalframenumber\fi
  }\hspace{1.2em}\vspace{0.8em}}

% ---- Semantic interface ----
% Key idea / punchline highlight
\newcommand{\KeyIdea}[1]{\textcolor{cHighlight}{\textbf{#1}}}
% One-line takeaway under an exhibit
\newcommand{\Takeaway}[1]{\par\smallskip\centering\footnotesize\textit{#1}\par}
% Gray inline citations: {\graycite{(Autor '13; Hjort-Poulsen '19)}}
\newcommand{\graycite}[1]{{\color{gray}\scriptsize #1}}
% Notation shortcut
\newcommand{\Et}{\mathbb{E}_t}
% Bold run-in label for structured summaries: \RunIn{Question:} ...
% Neutral bold on purpose: accents are reserved for taught concepts, and a
% structural label must not collide with the concept color map.
\newcommand{\RunIn}[1]{\textbf{#1}}

% Absolute-positioned nav buttons pinned bottom-right: never reflow the body
\newcommand{\PlaceNavShift}[2]{%
  \begin{tikzpicture}[remember picture,overlay]
    \node[anchor=south east, inner sep=0pt, outer sep=0pt]
      at ([xshift=#1,yshift=0.75cm]current page.south east) {#2};
  \end{tikzpicture}}
\newcommand{\PlaceNav}[1]{\PlaceNavShift{-2em}{#1}}
% Back button for appendix slides: \BackButton{main-slide-label}
\newcommand{\BackButton}[1]{\PlaceNav{\hyperlink{#1}{\beamerreturnbutton{Back}}}}

% Headline result box
\newtcolorbox{ResultBox}[1][Main result]{%
  colback=cAccentC!8, colframe=cAccentC, coltitle=white,
  title={\textbf{#1}}, fonttitle=\small,
  boxsep=2pt, top=3pt, bottom=3pt, left=6pt, right=6pt,
  boxrule=0.8pt, arc=1.5pt}

% Appendix divider frame + numbering switch
\newcommand{\AppendixStart}{%
  \appendix
  \begin{frame}[plain]\centering\vfill{\Huge\bfseries Appendix}\vfill\end{frame}%
  \addtocounter{framenumber}{-1}}

\endinput
